---
const { thick = false } = Astro.props;
---
<div class={`bias-mark ${thick ? 'bias-mark--thick' : ''}`} aria-hidden="true">
  <span class="bias-mark__rule bias-mark__rule--left"></span>
  <span class="bias-mark__square"></span>
  <span class="bias-mark__rule bias-mark__rule--right"></span>
</div>

<style>
  .bias-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0.75rem, 2vw, 1.5rem);
    padding: clamp(1.25rem, 3vw, 2rem) var(--pad-x);
    background: var(--otb-black);
  }
  .bias-mark--thick {
    padding: clamp(2rem, 4vw, 3rem) var(--pad-x);
  }
  .bias-mark__square {
    display: inline-block;
    width: 14px;
    height: 14px;
    background: var(--accent);
    flex-shrink: 0;
  }
  .bias-mark--thick .bias-mark__square {
    width: 20px;
    height: 20px;
  }
  .bias-mark__rule {
    flex: 1 1 0;
    height: 1px;
    background: var(--rule);
    max-width: 320px;
  }
</style>
