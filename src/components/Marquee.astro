---
const {
  text = 'Ο ΚΟΣΜΟΣ ΜΟΥ × FABULATOR QUI CONIUNGIT × DC · MILANO · PARIS · SFO × JACKWIESE',
  duration = 38,
  invert = false,
  reverse = false,
} = Astro.props;

const repeated = Array.from({ length: 6 }, () => text);
---
<div class={`marquee ${invert ? 'marquee--invert' : ''} ${reverse ? 'marquee--reverse' : ''}`} aria-hidden="true">
  <div class="marquee__track" style={`animation-duration:${duration}s`}>
    {repeated.map((t) => (
      <span class="marquee__chunk">
        {t.split('JACKWIESE').map((part, i, arr) => (
          <>
            {part}
            {i < arr.length - 1 && <strong>JACKWIESE</strong>}
          </>
        ))}
        <span class="marquee__sep"> × </span>
      </span>
    ))}
  </div>
</div>

<style>
  .marquee {
    width: 100%;
    overflow: hidden;
    background: var(--otb-black);
    color: var(--otb-white);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 0.65rem 0;
  }
  .marquee--invert {
    background: var(--otb-white);
    color: var(--otb-black);
    border-top-color: rgba(0,0,0,0.18);
    border-bottom-color: rgba(0,0,0,0.18);
  }
  .marquee__track {
    display: inline-flex;
    white-space: nowrap;
    animation: marquee-scroll 38s linear infinite;
    will-change: transform;
  }
  .marquee--reverse .marquee__track {
    animation-direction: reverse;
  }
  .marquee:hover .marquee__track {
    animation-play-state: paused;
  }
  .marquee__chunk {
    display: inline-block;
    padding-right: 2.5rem;
    font-family: 'NHaas Text';
    font-size: var(--scale-mono);
    letter-spacing: var(--track-upper);
    text-transform: uppercase;
  }
  .marquee__chunk strong {
    color: var(--accent);
    font-weight: 700;
  }
  .marquee__sep {
    opacity: 0.5;
  }
  @keyframes marquee-scroll {
    from { transform: translate3d(0, 0, 0); }
    to { transform: translate3d(-50%, 0, 0); }
  }
</style>
