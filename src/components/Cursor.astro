---
---
<div id="jw-cursor" aria-hidden="true">
  <svg viewBox="0 0 28 28" width="28" height="28">
    <polygon points="14,2 26,14 14,26 2,14" fill="none" stroke="#E30613" stroke-width="1.5" />
    <polygon points="14,11 17,14 14,17 11,14" fill="#E30613" />
  </svg>
</div>

<style>
  #jw-cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 28px;
    height: 28px;
    pointer-events: none;
    z-index: 9999;
    mix-blend-mode: difference;
    opacity: 0;
    transform: translate3d(-100px, -100px, 0);
    transition: opacity 180ms ease, scale 160ms ease;
    will-change: transform;
  }
  #jw-cursor.is-active {
    opacity: 0.92;
  }
  #jw-cursor.is-hover {
    scale: 1.18;
  }
  @media (hover: none), (max-width: 1023px), (prefers-reduced-motion: reduce) {
    #jw-cursor { display: none !important; }
  }

  /* Hide OS cursor on desktop everywhere - including interactive elements that
     normally swap to 'pointer'. Custom diamond is the only cursor users see. */
  @media (hover: hover) and (min-width: 1024px) and (prefers-reduced-motion: no-preference) {
    html, body, a, button, input, textarea, select, label, summary,
    [role="button"], [tabindex], [data-hover],
    .tile, .lp__item, .lp__toggle, .hover-reveal,
    .fact, .word-card, .word-card__title a {
      cursor: none !important;
    }
  }
</style>

<script is:inline>
  (() => {
    if (window.matchMedia('(hover: none)').matches) return;
    if (window.innerWidth < 1024) return;
    const cur = document.getElementById('jw-cursor');
    if (!cur) return;
    // Direct 1:1 tracking - no easing lag. Cursor sits exactly on the OS pointer position.
    document.addEventListener('mousemove', (e) => {
      cur.style.transform = `translate3d(${e.clientX - 14}px, ${e.clientY - 14}px, 0)`;
      if (!cur.classList.contains('is-active')) cur.classList.add('is-active');
    }, { passive: true });
    document.addEventListener('mouseleave', () => cur.classList.remove('is-active'));
    const hoverable = 'a, button, [data-hover], .tile, .hover-reveal, .fact, .lp__item, .lp__toggle';
    document.addEventListener('mouseover', (e) => {
      if (e.target instanceof Element && e.target.closest(hoverable)) cur.classList.add('is-hover');
    });
    document.addEventListener('mouseout', (e) => {
      if (e.target instanceof Element && e.target.closest(hoverable)) cur.classList.remove('is-hover');
    });
  })();
</script>
