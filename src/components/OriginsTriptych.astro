---
import { t, tArr } from '../i18n/t.js';
const L = Astro.currentLocale;
const captions = tArr(L, 'triptych.captions');
const numerals = tArr(L, 'triptych.numerals');

const IMAGES = [
  { src: '/images/young-dandy.jpg', alt: 'Jack as a child, Iowa', w: 632, h: 805 },
  { src: '/images/buy-back-farm.jpg', alt: 'The Wiese family farm in Iowa', w: 682, h: 881 },
  { src: '/images/jack-at-magic.jpg', alt: 'Jack at MAGIC trade show', w: 640, h: 831 },
];
---
<div class="triptych" aria-label="Origins">
  {IMAGES.map((img, i) => (
    <figure class="triptych__cell">
      <img src={img.src} alt={img.alt} width={img.w} height={img.h} loading="lazy" />
      <figcaption class="mono">
        {numerals[i] || `${i+1}.`} <span class="accent">{captions[i]?.lead}</span>{captions[i]?.body ? ` ${captions[i].body}` : ''}
      </figcaption>
    </figure>
  ))}
</div>

<style>
  .triptych {
    background: var(--otb-black);
    color: var(--otb-white);
    padding: clamp(3rem, 6vw, 5rem) var(--pad-x);
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: clamp(1rem, 2.5vw, 2.5rem);
  }
  @media (max-width: 760px) {
    .triptych { grid-template-columns: 1fr; }
  }
  .triptych__cell {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .triptych__cell img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    filter: grayscale(0.2) contrast(1.06) brightness(0.94);
  }
  .triptych__cell figcaption {
    color: var(--otb-mid-gray);
    line-height: 1.4;
  }
  .triptych__cell figcaption .accent {
    color: var(--accent);
  }
</style>
