---
const languages = [
  { code: 'en',    label: 'EN', name: 'English' },
  { code: 'es',    label: 'ES', name: 'Español' },
  { code: 'fr',    label: 'FR', name: 'Français' },
  { code: 'it',    label: 'IT', name: 'Italiano' },
  { code: 'de',    label: 'DE', name: 'Deutsch' },
  { code: 'pt',    label: 'PT', name: 'Português' },
  { code: 'nl',    label: 'NL', name: 'Nederlands' },
  { code: 'hi',    label: 'HI', name: 'हिन्दी' },
  { code: 'tr',    label: 'TR', name: 'Türkçe' },
  { code: 'ar',    label: 'AR', name: 'العربية' },
  { code: 'ko',    label: 'KO', name: '한국어' },
  { code: 'zh-CN', label: 'ZH', name: '中文' },
  { code: 'ja',    label: 'JA', name: '日本語' },
  { code: 'ru',    label: 'RU', name: 'Русский' },
  { code: 'zh-TW', label: 'ZH', name: '繁體中文' },
  { code: 'vi',    label: 'VI', name: 'Tiếng Việt' },
  { code: 'id',    label: 'ID', name: 'Bahasa Indonesia' },
];
---
<div class="lp" data-lp translate="no">
  <button
    type="button"
    class="lp__toggle mono"
    data-lp-toggle
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-label="Change language"
  >
    <span data-lp-current>EN</span>
    <svg viewBox="0 0 10 6" width="10" height="6" aria-hidden="true">
      <polyline points="1,1 5,5 9,1" fill="none" stroke="currentColor" stroke-width="1.5" />
    </svg>
  </button>

  <ul class="lp__menu" data-lp-menu role="listbox" aria-label="Languages" hidden>
    {languages.map((l) => (
      <li>
        <button
          type="button"
          class="lp__item"
          role="option"
          data-lp-lang={l.code}
          data-lp-label={l.label}
        >
          <span class="lp__code mono">{l.label}</span>
          <span class="lp__name">{l.name}</span>
        </button>
      </li>
    ))}
  </ul>
</div>

<style>
  .lp {
    position: fixed;
    top: clamp(0.6rem, 1.2vw, 1rem);
    right: clamp(0.6rem, 1.2vw, 1rem);
    z-index: 8500;
    font-family: 'NHaas Text';
  }
  .lp__toggle {
    appearance: none;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    border: 1px solid var(--accent);
    color: var(--otb-white);
    padding: 0.45rem 0.65rem 0.35rem 0.7rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-size: 0.78rem;
    letter-spacing: var(--track-upper);
    text-transform: uppercase;
    transition: background 140ms ease;
  }
  .lp__toggle:hover { background: var(--accent); }
  .lp__toggle svg { transition: transform 200ms ease; }
  .lp__toggle[aria-expanded="true"] svg { transform: rotate(180deg); }

  .lp__menu {
    list-style: none;
    margin: 0.4rem 0 0;
    padding: 0.4rem 0;
    background: var(--otb-black);
    border: 1px solid var(--accent);
    min-width: 220px;
    max-height: 60vh;
    overflow-y: auto;
    box-shadow: 0 14px 32px -16px rgba(0,0,0,0.7);
    position: absolute;
    right: 0;
    top: 100%;
    scrollbar-color: var(--accent) rgba(255,255,255,0.05);
    scrollbar-width: thin;
  }
  .lp__menu::-webkit-scrollbar { width: 6px; }
  .lp__menu::-webkit-scrollbar-thumb { background: var(--accent); }

  .lp__item {
    appearance: none;
    background: transparent;
    border: 0;
    width: 100%;
    text-align: left;
    padding: 0.5rem 0.85rem;
    color: var(--otb-light-gray);
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    cursor: pointer;
    transition: background 120ms ease, color 120ms ease;
  }
  .lp__item:hover,
  .lp__item:focus-visible,
  .lp__item[aria-selected="true"] {
    background: rgba(227, 6, 19, 0.18);
    color: var(--otb-white);
  }
  .lp__code {
    color: var(--accent);
    font-size: 0.72rem;
    letter-spacing: var(--track-upper);
    min-width: 2.2rem;
  }
  .lp__name {
    font-size: 0.92rem;
  }

  @media (max-width: 640px) {
    .lp { top: 0.35rem; right: 0.35rem; }
    .lp__menu { min-width: 200px; max-height: 70vh; }
  }
</style>

<script type="application/json" id="lp-langs" set:html={JSON.stringify(languages)}></script>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-lp]');
    if (!root) return;
    const toggle = root.querySelector('[data-lp-toggle]');
    const menu = root.querySelector('[data-lp-menu]');
    const curEl = root.querySelector('[data-lp-current]');

    // Detect if we are already on a translate.goog mirror (URL contains '.translate.goog')
    // and pull the current target language so the chip reflects it.
    const detectActive = () => {
      const host = window.location.hostname;
      const m = host.match(/^([^.]+)\.translate\.goog$/i);
      if (!m) {
        // We are on the canonical site - language is English (or browser-native).
        // Also pull from URL ?_x_tr_tl in case Google appended it.
        const tl = new URLSearchParams(window.location.search).get('_x_tr_tl');
        return tl || 'en';
      }
      // On a translated mirror, the current target language sits in the query string.
      const tl = new URLSearchParams(window.location.search).get('_x_tr_tl');
      return tl || 'en';
    };

    const currentCode = detectActive();
    const langs = JSON.parse(document.getElementById('lp-langs').textContent);
    const currentLang = langs.find((l) => l.code.toLowerCase() === currentCode.toLowerCase()) || langs[0];
    if (curEl) curEl.textContent = currentLang.label;
    if (currentCode === 'ar' || currentCode === 'fa' || currentCode === 'he') {
      document.documentElement.setAttribute('dir', 'rtl');
    }

    const open = () => { menu.hidden = false; toggle.setAttribute('aria-expanded', 'true'); };
    const close = () => { menu.hidden = true; toggle.setAttribute('aria-expanded', 'false'); };
    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      menu.hidden ? open() : close();
    });
    document.addEventListener('click', (e) => {
      if (!root.contains(e.target)) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.hidden) { close(); toggle.focus(); }
    });

    // Navigate to the translate.goog mirror of the canonical site for the chosen language.
    // Reliable on every browser including mobile Safari - no widget, no DOM injection.
    const CANONICAL = 'jackbwiese.github.io';
    const CANONICAL_MIRROR = 'jackbwiese-github-io.translate.goog';
    const goTo = (code) => {
      const path = window.location.pathname + window.location.search.replace(/[?&]_x_tr_[^=]+=[^&]*/g, '').replace(/^&/, '?') + window.location.hash;
      let url;
      if (code === 'en') {
        // English = canonical site
        url = 'https://' + CANONICAL + path;
      } else {
        url = 'https://' + CANONICAL_MIRROR + path
          + (path.includes('?') ? '&' : '?')
          + '_x_tr_sl=en&_x_tr_tl=' + encodeURIComponent(code) + '&_x_tr_hl=en';
      }
      window.location.href = url;
    };

    root.querySelectorAll('[data-lp-lang]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const code = btn.getAttribute('data-lp-lang');
        goTo(code);
        close();
      });
    });
  })();
</script>
