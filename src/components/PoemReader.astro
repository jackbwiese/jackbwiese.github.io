---
import poem from '../data/poem.json';

const romans = ['i','ii','iii','iv','v','vi','vii','viii','ix','x',
  'xi','xii','xiii','xiv','xv','xvi','xvii','xviii','xix','xx',
  'xxi','xxii','xxiii','xxiv','xxv','xxvi','xxvii','xxviii','xxix','xxx'];
---
<div class="poem">
  <button
    type="button"
    class="poem__toggle"
    data-poem-toggle
    aria-expanded="false"
    aria-controls="poem-reader"
  >
    <span class="poem__toggle-text" data-toggle-text>Read the entire series</span>
    <span class="poem__toggle-arrow" aria-hidden="true">↓</span>
  </button>

  <div id="poem-reader" class="poem__reader" data-poem-reader hidden>
    <header class="poem__header">
      <p class="mono poem__eyebrow">A Series of Poems About Someone Who Will Never Read Them</p>
      <p class="mono poem__byline">by Jack Wiese · {poem.sections.length} parts</p>
    </header>

    <div class="poem__scroll" data-poem-scroll>
      {poem.sections.map((section, i) => (
        <article class="poem__section" id={`poem-${i+1}`}>
          <header class="poem__section-head">
            <span class="poem__section-n mono">{romans[i] || (i+1)}.</span>
            <h3 class="poem__section-title">{section.title}</h3>
          </header>
          {section.blocks.map((b) => (
            b.type === 'prose' ? (
              <p class="poem__prose">{b.text}</p>
            ) : (
              <div class="poem__verse">
                {b.lines.map((line) => <p class="poem__line">{line}</p>)}
              </div>
            )
          ))}
        </article>
      ))}

      <footer class="poem__footer">
        <p class="mono">— end of series —</p>
        <button type="button" class="poem__close mono" data-poem-collapse>
          ↑ Collapse
        </button>
      </footer>
    </div>
  </div>
</div>

<style>
  .poem {
    margin-top: 1.25rem;
  }
  .poem__toggle {
    appearance: none;
    background: transparent;
    border: 1px solid var(--accent);
    color: var(--accent);
    padding: 0.7rem 1.1rem 0.6rem;
    font-family: 'NHaas Text';
    font-size: var(--scale-mono);
    letter-spacing: var(--track-upper);
    text-transform: uppercase;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    transition: background 140ms ease, color 140ms ease;
  }
  .poem__toggle:hover {
    background: var(--accent);
    color: var(--otb-white);
  }
  .poem__toggle-arrow {
    display: inline-block;
    transition: transform 240ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .poem__toggle[aria-expanded="true"] .poem__toggle-arrow {
    transform: rotate(180deg);
  }

  .poem__reader {
    margin-top: 1.5rem;
    border: 1px solid var(--rule);
    background: rgba(255, 255, 255, 0.02);
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 320ms ease, transform 320ms ease;
  }
  .poem__reader:not([hidden]) {
    opacity: 1;
    transform: translateY(0);
  }

  .poem__header {
    padding: 1.25rem 1.5rem 0.9rem;
    border-bottom: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .poem__eyebrow {
    color: var(--otb-light-gray);
  }
  .poem__byline {
    color: var(--otb-mid-gray);
  }

  .poem__scroll {
    max-height: 72vh;
    overflow-y: auto;
    padding: 0.5rem clamp(1rem, 3vw, 2.5rem) 1.5rem;
    scrollbar-color: var(--accent) rgba(255,255,255,0.05);
    scrollbar-width: thin;
  }
  .poem__scroll::-webkit-scrollbar {
    width: 8px;
  }
  .poem__scroll::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.04);
  }
  .poem__scroll::-webkit-scrollbar-thumb {
    background: var(--accent);
  }

  .poem__section {
    padding: 1.75rem 0;
    border-top: 1px dotted rgba(255,255,255,0.18);
  }
  .poem__section:first-child {
    border-top: 0;
    padding-top: 0.5rem;
  }
  .poem__section-head {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    margin-bottom: 1rem;
  }
  .poem__section-n {
    color: var(--accent);
    flex-shrink: 0;
  }
  .poem__section-title {
    font-family: 'NHaas Display';
    font-weight: 400;
    font-size: clamp(1.4rem, 2.5vw, 1.95rem);
    line-height: 1.05;
    letter-spacing: var(--track-tight);
    margin: 0;
    color: var(--otb-white);
  }
  .poem__prose {
    font-family: 'NHaas Text';
    font-size: 1rem;
    line-height: 1.65;
    color: var(--otb-light-gray);
    max-width: 64ch;
    margin: 0 0 1em;
  }
  .poem__verse {
    font-family: 'NHaas Display';
    font-weight: 300;
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--otb-white);
    letter-spacing: var(--track-base);
  }
  .poem__line {
    margin: 0;
    font-style: italic;
  }
  .poem__line + .poem__line {
    margin-top: 0.05rem;
  }

  .poem__footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--rule);
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--otb-mid-gray);
  }
  .poem__close {
    appearance: none;
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--otb-light-gray);
    padding: 0.5rem 0.85rem 0.4rem;
    cursor: pointer;
    transition: color 140ms ease, border-color 140ms ease;
  }
  .poem__close:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  @media (max-width: 760px) {
    .poem__scroll {
      max-height: 64vh;
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }
</style>

<script is:inline>
  (() => {
    const toggle = document.querySelector('[data-poem-toggle]');
    const reader = document.querySelector('[data-poem-reader]');
    const txt = document.querySelector('[data-toggle-text]');
    const close = document.querySelector('[data-poem-collapse]');
    if (!toggle || !reader) return;

    const open = () => {
      reader.hidden = false;
      requestAnimationFrame(() => {
        reader.style.opacity = '1';
        reader.style.transform = 'translateY(0)';
      });
      toggle.setAttribute('aria-expanded', 'true');
      if (txt) txt.textContent = 'Close the series';
    };
    const shut = () => {
      reader.style.opacity = '0';
      reader.style.transform = 'translateY(-6px)';
      setTimeout(() => { reader.hidden = true; }, 320);
      toggle.setAttribute('aria-expanded', 'false');
      if (txt) txt.textContent = 'Read the entire series';
      toggle.scrollIntoView({ behavior: 'smooth', block: 'center' });
    };

    toggle.addEventListener('click', () => {
      if (reader.hidden) open(); else shut();
    });
    if (close) close.addEventListener('click', shut);
  })();
</script>
