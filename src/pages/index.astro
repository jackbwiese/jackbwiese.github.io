---
import Base from '../layouts/Base.astro';
import Cursor from '../components/Cursor.astro';
import CityClockMarquee from '../components/CityClockMarquee.astro';
import EasterEgg from '../components/EasterEgg.astro';
import SectionDivider from '../components/SectionDivider.astro';

import Hero from '../sections/Hero.astro';
import Manifesto from '../sections/Manifesto.astro';
import Vita from '../sections/Vita.astro';
import Worldview from '../sections/Worldview.astro';
import Arsenal from '../sections/Arsenal.astro';
import Obsessions from '../sections/Obsessions.astro';
import CabinetDeCuriosites from '../sections/CabinetDeCuriosites.astro';
import Correspondance from '../sections/Correspondance.astro';
import Footer from '../sections/Footer.astro';
---
<Base>
  <Cursor />

  <Hero />
  <CityClockMarquee />

  <Manifesto />
  <CityClockMarquee reverse={true} duration={48} />

  <Vita />
  <SectionDivider />

  <Worldview />
  <CityClockMarquee />

  <Arsenal />
  <SectionDivider thick={true} />

  <Obsessions />
  <CityClockMarquee reverse={true} duration={52} />

  <CabinetDeCuriosites />
  <SectionDivider />

  <Correspondance />
  <CityClockMarquee />

  <Footer />

  <EasterEgg />
</Base>
