---
import HoverReveal from '../components/HoverReveal.astro';
import PoemReader from '../components/PoemReader.astro';
import PensiveBoutsGallery from '../components/PensiveBoutsGallery.astro';

const literature = [
  'Cervantes - Don Quixote',
  'Homer - Iliad & Odyssey',
  'Tolstoy - War and Peace',
  'Shakespeare - the late tragedies',
  'Emerson - Essays & Self-Reliance',
  'Marcus Aurelius - Meditations',
  'Dante - Divina Commedia',
  'Dumas - The Three Musketeers',
  'Kerouac - On the Road',
  'Hemingway - For Whom the Bell Tolls',
  'Chaucer - Canterbury Tales',
  'Laclos - Les Liaisons Dangereuses',
];

const history = [
  'The Age of Sail · 1500-1850',
  'Pirates of the Caribbean & Pacific',
  'Mediaeval Europe & Chivalric Orders',
  'Ancient Greece + Rome',
  'Revolutions: 1776 · 1789 · 1848 · 1917',
  'Habsburg, Bourbon, Romanov',
  'Renaissance Florence',
  'Edo Japan',
  'Any period of profound paradigm shift.',
];

const languages = ['EN', 'FR', 'ES', 'IT', 'DE', 'EL'];
---
<section class="section obsessions" id="obsessions">
  <span class="eyebrow">§ VI · Obsessions</span>
  <h2 class="obsessions__heading">What I read, what I love, how I think.</h2>

  <figure class="obsessions__hero">
    <img
      src="/images/quixote-quando-non-posso.jpg"
      alt="Don Quixote on the moor, lance raised, Sancho watching"
      width="1300"
      height="1012"
      loading="lazy"
    />
    <figcaption class="mono">
      <span class="accent">Don Quijote:</span>
      The patron saint of doing it anyway.
    </figcaption>
  </figure>

  <div class="obsessions__grid">
    <article class="obsessions__col">
      <h3 class="obsessions__h">Literature</h3>
      <p class="obsessions__prose">
        <span class="obsessions__lead">Some favorites:</span> {literature.join(', ')}.
      </p>
    </article>

    <article class="obsessions__col">
      <h3 class="obsessions__h">History</h3>
      <ul class="obsessions__list">
        {history.map((l) => <li>{l}</li>)}
      </ul>
    </article>

    <article class="obsessions__col">
      <h3 class="obsessions__h">Languages</h3>
      <div class="lang-row">
        {languages.map((l) => <span class="lang-chip">{l}</span>)}
      </div>
      <p class="obsessions__caption mono">
        Lifetime goal: <span class="accent">twelve</span>.
      </p>
    </article>
  </div>

  <hr class="rule" />

  <div class="obsessions__art">
    <p class="eyebrow">Making, beyond the desk</p>
    <p class="obsessions__art-lede">
      Sculpture, painting, dance, running, travel. The
      <HoverReveal src="/images/vfma-3.jpg" alt="Sculpture, salvaged piano">salvaged-piano piece</HoverReveal>,
      the
      <HoverReveal src="/images/vfma-5.jpg" alt="Sculpture, plaster and hangers">plaster + hangers + fabric assemblage</HoverReveal>,
      and the
      <HoverReveal src="/images/vfma-1.jpg" alt="Studio work">studio work</HoverReveal>
      live in the same head as the company. They are not a hobby; they are the source code.
    </p>
  </div>

  <hr class="rule" />

  <div class="obsessions__words">
    <p class="eyebrow">In other forms</p>
    <div class="obsessions__words-grid">
      <article class="word-card">
        <header class="word-card__head">
          <span class="word-card__n mono">i.</span>
          <span class="word-card__kind mono">Writings</span>
        </header>
        <h3 class="word-card__title">A Series of Poems About Someone Who Will Never Read Them</h3>
        <p class="word-card__body">
          An ongoing series. A testament addressed to a reader who is not watching -
          to remember the people whose impact persisted long after their presence faded.
        </p>
        <blockquote class="word-card__excerpt">
          <p>
            "As a boy grows into a man,<br />
            they forget childhood bliss, the days playing in the sand.<br />
            <span class="opacity-pull">[ ... ]</span><br />
            And though you may never read this series of poems,<br />
            I hope you somehow know, thanks to you with myself I can now feel at home."
          </p>
          <footer class="mono">from <em>Grow Up, Forget!</em></footer>
        </blockquote>
        <PoemReader />
      </article>

      <article class="word-card">
        <header class="word-card__head">
          <span class="word-card__n mono">ii.</span>
          <span class="word-card__kind mono">Sound</span>
        </header>
        <h3 class="word-card__title">
          <a href="https://www.youtube.com/@pensivebouts" rel="noopener" target="_blank">Pensive Bouts ↗</a>
        </h3>
        <p class="word-card__body">
          For a brief season I kept an auditory journal under the moniker
          <em>Pensive Bouts</em>. Quiet hours, recorded out loud. A parenthesis.
        </p>
        <PensiveBoutsGallery />
      </article>
    </div>
  </div>
</section>

<style>
  .obsessions {
    background: var(--otb-black);
    color: var(--otb-white);
  }
  .obsessions__heading {
    font-size: clamp(1.75rem, 4.5vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: var(--track-tight);
    margin-bottom: clamp(2.5rem, 5vw, 4.5rem);
    max-width: 24ch;
  }
  .obsessions__grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: clamp(1.5rem, 3vw, 3.5rem);
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }
  @media (max-width: 900px) {
    .obsessions__grid { grid-template-columns: 1fr; }
  }
  .obsessions__col {
    border-top: 1px solid var(--accent);
    padding-top: 1rem;
  }
  .obsessions__h {
    font-size: 1.15rem;
    text-transform: uppercase;
    letter-spacing: var(--track-upper);
    color: var(--otb-light-gray);
    margin-bottom: 1rem;
    font-family: 'NHaas Text';
    font-weight: 500;
  }
  .obsessions__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    color: var(--otb-light-gray);
  }
  .obsessions__list li {
    font-size: var(--scale-body);
    line-height: 1.4;
  }
  .obsessions__list li:last-child {
    color: var(--accent);
    padding-top: 0.5rem;
    font-style: italic;
  }
  .obsessions__prose {
    font-size: var(--scale-body);
    line-height: 1.55;
    color: var(--otb-light-gray);
    margin: 0;
  }
  .obsessions__lead {
    color: var(--accent);
    font-style: italic;
  }
  .lang-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.5rem 0 1.25rem;
  }
  .lang-chip {
    font-family: 'NHaas Display';
    font-weight: 400;
    font-size: 1.15rem;
    letter-spacing: var(--track-tight);
    padding: 0.35rem 0.7rem 0.25rem;
    border: 1px solid var(--otb-white);
    color: var(--otb-white);
    line-height: 1;
  }
  .lang-chip:last-child {
    color: var(--accent);
    border-color: var(--accent);
  }
  .obsessions__caption {
    color: var(--otb-mid-gray);
    margin-top: 0.5rem;
  }
  .obsessions__caption .accent { color: var(--accent); }
  .obsessions__art {
    padding-top: 2.5rem;
  }
  .obsessions__art-lede {
    font-family: 'NHaas Display';
    font-weight: 300;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    line-height: 1.2;
    letter-spacing: var(--track-tight);
    max-width: 40ch;
    color: var(--otb-white);
  }
  .obsessions__art-lede :global(.hover-reveal) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 4px;
  }

  .obsessions__hero {
    margin: 0 0 clamp(3rem, 6vw, 5rem);
    max-width: min(560px, 55%);
    position: relative;
  }
  .obsessions__hero img {
    display: block;
    width: 100%;
    height: auto;
    filter: contrast(1.05);
  }
  @media (max-width: 760px) {
    .obsessions__hero { max-width: 100%; }
  }
  .obsessions__hero figcaption {
    margin-top: 0.85rem;
    color: var(--otb-mid-gray);
    line-height: 1.45;
  }
  .obsessions__hero figcaption .accent { color: var(--accent); }

  .obsessions__words {
    padding-top: 2.5rem;
  }
  .obsessions__words-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 3vw, 3rem);
    margin-top: 1.5rem;
  }
  @media (max-width: 760px) {
    .obsessions__words-grid { grid-template-columns: 1fr; }
  }
  .word-card {
    border-top: 1px solid var(--accent);
    padding-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .word-card__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    color: var(--otb-mid-gray);
  }
  .word-card__n { color: var(--accent); }
  .word-card__title {
    font-size: clamp(1.35rem, 2.3vw, 1.85rem);
    line-height: 1.1;
    letter-spacing: var(--track-tight);
    margin: 0;
    max-width: 24ch;
  }
  .word-card__title a {
    border: 0;
    background: linear-gradient(to top, var(--accent) 0%, var(--accent) 6%, transparent 6%);
    padding-bottom: 2px;
  }
  .word-card__title a:hover { color: var(--accent); }
  .word-card__body {
    font-size: var(--scale-body);
    line-height: 1.55;
    color: var(--otb-light-gray);
    margin: 0;
    max-width: 38ch;
  }
  .word-card__excerpt {
    margin: 1rem 0 0;
    padding: 1rem 0 0;
    border-top: 1px dotted rgba(255, 255, 255, 0.22);
    font-family: 'NHaas Display';
    font-weight: 300;
    font-size: 1.05rem;
    line-height: 1.55;
    font-style: italic;
    color: var(--otb-white);
  }
  .word-card__excerpt p { margin: 0; }
  .word-card__excerpt .opacity-pull {
    color: var(--accent);
    letter-spacing: var(--track-upper);
    font-style: normal;
    font-size: 0.85em;
  }
  .word-card__excerpt footer {
    margin-top: 0.75rem;
    color: var(--otb-mid-gray);
    font-style: normal;
  }
  .word-card__excerpt footer em {
    color: var(--accent);
    font-style: italic;
  }
  .word-card__embed {
    margin-top: 1rem;
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--otb-black);
    border: 1px solid var(--rule);
    overflow: hidden;
  }
  .word-card__embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
