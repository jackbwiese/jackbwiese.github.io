---
import PoemReader from '../components/PoemReader.astro';
import PensiveBoutsGallery from '../components/PensiveBoutsGallery.astro';
import { t, tArr } from '../i18n/t.js';

const L = Astro.currentLocale;
const literature = tArr(L, 'obsessions.literature');
const history = tArr(L, 'obsessions.history');
const languages = ['EN', 'FR', 'ES', 'IT', 'DE', 'EL'];
---
<section class="section obsessions" id="obsessions">
  <span class="eyebrow">{t(L, 'obsessions.eyebrow')}</span>
  <h2 class="obsessions__heading">{t(L, 'obsessions.heading')}</h2>

  <figure class="obsessions__hero">
    <img
      src="/images/quixote-quando-non-posso.jpg"
      alt="Don Quixote on the moor, lance raised, Sancho watching"
      width="1300"
      height="1012"
      loading="lazy"
    />
    <figcaption class="mono">
      <span class="accent" translate="no">{t(L, 'obsessions.paintingCaptionLead')}</span>
      {t(L, 'obsessions.paintingCaption')}
    </figcaption>
  </figure>

  <div class="obsessions__grid">
    <article class="obsessions__col">
      <h3 class="obsessions__h">{t(L, 'obsessions.literatureHeader')}</h3>
      <p class="obsessions__prose">
        <span class="obsessions__lead">{t(L, 'obsessions.literatureLead')}</span> {literature.join(', ')}.
      </p>
    </article>

    <article class="obsessions__col">
      <h3 class="obsessions__h">{t(L, 'obsessions.historyHeader')}</h3>
      <p class="obsessions__prose">
        <span class="obsessions__lead">{t(L, 'obsessions.historyLead')}</span> {history.join(', ')}.
      </p>
    </article>

    <article class="obsessions__col">
      <h3 class="obsessions__h">{t(L, 'obsessions.languagesHeader')}</h3>
      <div class="lang-row">
        {languages.map((l) => <span class="lang-chip" translate="no">{l}</span>)}
      </div>
      <p class="obsessions__caption mono">
        {t(L, 'obsessions.languagesGoalPrefix')} <span class="accent">{t(L, 'obsessions.languagesGoalWord')}</span>{t(L, 'obsessions.languagesGoalPunct')}
      </p>
    </article>
  </div>

  <hr class="rule" />

  <div class="obsessions__art">
    <p class="eyebrow">{t(L, 'obsessions.makingHeader')}</p>
    <p class="obsessions__art-lede">
      {t(L, 'obsessions.makingBody')}
    </p>
  </div>

  <hr class="rule" />

  <div class="obsessions__words">
    <p class="eyebrow">{t(L, 'obsessions.inOtherFormsLabel')}</p>
    <div class="obsessions__words-grid">
      <article class="word-card">
        <header class="word-card__head">
          <span class="word-card__n mono">i.</span>
          <span class="word-card__kind mono">{t(L, 'obsessions.writingsKind')}</span>
        </header>
        <h3 class="word-card__title">{t(L, 'obsessions.writingsTitle')}</h3>
        <p class="word-card__body">
          {t(L, 'obsessions.writingsBody')}
        </p>
        <blockquote class="word-card__excerpt">
          <p>
            "As a boy grows into a man,<br />
            they forget childhood bliss, the days playing in the sand.<br />
            <span class="opacity-pull">[ ... ]</span><br />
            And though you may never read this series of poems,<br />
            I hope you somehow know, thanks to you with myself I can now feel at home."
          </p>
          <footer class="mono">{t(L, 'obsessions.grewUpForget')} <em>Grow Up, Forget!</em></footer>
        </blockquote>
        <PoemReader />
      </article>

      <article class="word-card">
        <header class="word-card__head">
          <span class="word-card__n mono">ii.</span>
          <span class="word-card__kind mono">{t(L, 'obsessions.soundKind')}</span>
        </header>
        <h3 class="word-card__title">
          <a href="https://www.youtube.com/@pensivebouts" rel="noopener" target="_blank" translate="no">{t(L, 'obsessions.soundTitle')} ↗</a>
        </h3>
        <p class="word-card__body">
          {t(L, 'obsessions.soundBody')}
        </p>
        <PensiveBoutsGallery />
      </article>
    </div>
  </div>
</section>

<style>
  .obsessions {
    background: var(--otb-black);
    color: var(--otb-white);
  }
  .obsessions__heading {
    font-size: clamp(1.75rem, 4.5vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: var(--track-tight);
    margin-bottom: clamp(2.5rem, 5vw, 4.5rem);
    max-width: 24ch;
  }
  .obsessions__grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: clamp(1.5rem, 3vw, 3.5rem);
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }
  @media (max-width: 900px) {
    .obsessions__grid { grid-template-columns: 1fr; }
  }
  .obsessions__col {
    border-top: 1px solid var(--accent);
    padding-top: 1rem;
  }
  .obsessions__h {
    font-size: 1.15rem;
    text-transform: uppercase;
    letter-spacing: var(--track-upper);
    color: var(--otb-light-gray);
    margin-bottom: 1rem;
    font-family: 'NHaas Text';
    font-weight: 500;
  }
  .obsessions__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    color: var(--otb-light-gray);
  }
  .obsessions__list li {
    font-size: var(--scale-body);
    line-height: 1.4;
  }
  .obsessions__list li:last-child {
    color: var(--accent);
    padding-top: 0.5rem;
    font-style: italic;
  }
  .obsessions__prose {
    font-size: var(--scale-body);
    line-height: 1.55;
    color: var(--otb-light-gray);
    margin: 0;
  }
  .obsessions__lead {
    color: var(--accent);
    font-style: italic;
  }
  .lang-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.5rem 0 1.25rem;
  }
  .lang-chip {
    font-family: 'NHaas Display';
    font-weight: 400;
    font-size: 1.15rem;
    letter-spacing: var(--track-tight);
    padding: 0.35rem 0.7rem 0.25rem;
    border: 1px solid var(--otb-white);
    color: var(--otb-white);
    line-height: 1;
  }
  .lang-chip:last-child {
    color: var(--accent);
    border-color: var(--accent);
  }
  .obsessions__caption {
    color: var(--otb-mid-gray);
    margin-top: 0.5rem;
  }
  .obsessions__caption .accent { color: var(--accent); }
  .obsessions__art {
    padding-top: 2.5rem;
  }
  .obsessions__art-lede {
    font-family: 'NHaas Display';
    font-weight: 300;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    line-height: 1.2;
    letter-spacing: var(--track-tight);
    max-width: 40ch;
    color: var(--otb-white);
  }

  .obsessions__hero {
    margin: 0 0 clamp(3rem, 6vw, 5rem);
    max-width: min(560px, 55%);
    position: relative;
  }
  .obsessions__hero img {
    display: block;
    width: 100%;
    height: auto;
    filter: contrast(1.05);
  }
  @media (max-width: 760px) {
    .obsessions__hero { max-width: 100%; }
  }
  .obsessions__hero figcaption {
    margin-top: 0.85rem;
    color: var(--otb-mid-gray);
    line-height: 1.45;
  }
  .obsessions__hero figcaption .accent { color: var(--accent); }

  .obsessions__words {
    padding-top: 2.5rem;
  }
  .obsessions__words-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 3vw, 3rem);
    margin-top: 1.5rem;
  }
  @media (max-width: 760px) {
    .obsessions__words-grid { grid-template-columns: 1fr; }
  }
  .word-card {
    border-top: 1px solid var(--accent);
    padding-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .word-card__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    color: var(--otb-mid-gray);
  }
  .word-card__n { color: var(--accent); }
  .word-card__title {
    font-size: clamp(1.35rem, 2.3vw, 1.85rem);
    line-height: 1.1;
    letter-spacing: var(--track-tight);
    margin: 0;
    max-width: 24ch;
  }
  .word-card__title a {
    border: 0;
    background: linear-gradient(to top, var(--accent) 0%, var(--accent) 6%, transparent 6%);
    padding-bottom: 2px;
  }
  .word-card__title a:hover { color: var(--accent); }
  .word-card__body {
    font-size: var(--scale-body);
    line-height: 1.55;
    color: var(--otb-light-gray);
    margin: 0;
    max-width: 38ch;
  }
  .word-card__excerpt {
    margin: 1rem 0 0;
    padding: 1rem 0 0;
    border-top: 1px dotted rgba(255, 255, 255, 0.22);
    font-family: 'NHaas Display';
    font-weight: 300;
    font-size: 1.05rem;
    line-height: 1.55;
    font-style: italic;
    color: var(--otb-white);
  }
  .word-card__excerpt p { margin: 0; }
  .word-card__excerpt .opacity-pull {
    color: var(--accent);
    letter-spacing: var(--track-upper);
    font-style: normal;
    font-size: 0.85em;
  }
  .word-card__excerpt footer {
    margin-top: 0.75rem;
    color: var(--otb-mid-gray);
    font-style: normal;
  }
  .word-card__excerpt footer em {
    color: var(--accent);
    font-style: italic;
  }
  .word-card__embed {
    margin-top: 1rem;
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--otb-black);
    border: 1px solid var(--rule);
    overflow: hidden;
  }
  .word-card__embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
