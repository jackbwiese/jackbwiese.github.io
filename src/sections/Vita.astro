---
import { t, tArr } from '../i18n/t.js';
const L = Astro.currentLocale;
const paragraphs = tArr(L, 'vita.paragraphs');
---
<section class="section vita" id="vita">
  <span class="eyebrow">{t(L, 'vita.eyebrow')}</span>

  <div class="bias-grid vita__grid">
    <figure class="vita__figure">
      <img
        src="/images/portrait-romulus-carre.jpg"
        alt="Jack von Wiese und Kaiserswaldau"
        width="1200"
        height="1200"
        loading="lazy"
      />
      <figcaption class="mono">{t(L, 'vita.portraitCaption')}</figcaption>
    </figure>

    <div class="vita__text">
      {paragraphs.map((p) => <p>{p}</p>)}
    </div>
  </div>
</section>

<style>
  .vita {
    background: var(--otb-black);
    color: var(--otb-white);
  }
  .vita__grid {
    align-items: start;
    gap: clamp(2rem, 5vw, 5rem);
  }
  .vita__figure {
    margin: 0;
    position: relative;
  }
  .vita__figure img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    filter: contrast(1.08) saturate(0.88) brightness(0.96);
  }
  .vita__figure figcaption {
    margin-top: 0.65rem;
    color: var(--otb-mid-gray);
  }
  .vita__text {
    padding-top: 0.25rem;
    color: var(--otb-light-gray);
  }
  .vita__text p {
    font-size: var(--scale-lede);
    line-height: 1.5;
    max-width: 56ch;
  }
  .vita__text strong {
    font-weight: 500;
    color: var(--otb-white);
  }
  .vita__text em {
    color: var(--otb-white);
  }
</style>
