---
import { t, tArr } from '../i18n/t.js';
const L = Astro.currentLocale;
const theses = tArr(L, 'worldview.theses');
---
<section class="section worldview" id="worldview">
  <span class="eyebrow">{t(L, 'worldview.eyebrow')}</span>
  <div class="worldview__grid">
    {theses.map((thesis, i) => (
      <article class="worldview__col">
        <span class="worldview__n">{String(i + 1).padStart(2, '0')}</span>
        <h3 class="worldview__h">{thesis.title}</h3>
        <p class="worldview__body">{thesis.body}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .worldview {
    background: var(--otb-black);
    color: var(--otb-white);
  }
  .worldview__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    margin-bottom: clamp(3rem, 7vw, 5rem);
    max-width: 1100px;
    margin-inline: auto;
  }
  @media (max-width: 760px) {
    .worldview__grid {
      grid-template-columns: 1fr;
    }
  }
  .worldview__col {
    border-top: 1px solid var(--accent);
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .worldview__n {
    font-family: 'NHaas Text';
    font-size: var(--scale-mono);
    letter-spacing: var(--track-upper);
    color: var(--accent);
  }
  .worldview__h {
    font-size: clamp(1.6rem, 2.8vw, 2.4rem);
    line-height: 1.08;
    letter-spacing: var(--track-tight);
    max-width: 22ch;
  }
  .worldview__body {
    font-size: var(--scale-body);
    line-height: 1.6;
    color: var(--otb-light-gray);
    max-width: 46ch;
  }
</style>
