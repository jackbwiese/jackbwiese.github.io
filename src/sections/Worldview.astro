---
const theses = [
  {
    n: '01',
    title: 'Technology should free humanity to make.',
    body: 'The printing press freed reading. The loom freed weaving. Software freed writing. The next layer does not replace the creator - it removes the secretarial labor between a vision and its realization. The result is not fewer artists but a civilization of them. Taste becomes the moat. The patron returns.',
  },
  {
    n: '02',
    title: 'Live the impossible thing, anyway.',
    body: 'Don Quixote tilts at windmills and history calls him mad. The world prefers smaller, easier versions of us. Refuse to negotiate yourself down. To live as your fullest, boldest, most chivalric self in a flattened century is not delusion - it is the only honest thing left. Choose the windmill.',
  },
];
---
<section class="section worldview" id="worldview">
  <span class="eyebrow">§ III · Worldview</span>
  <div class="worldview__grid">
    {theses.map((t) => (
      <article class="worldview__col">
        <span class="worldview__n">{t.n}</span>
        <h3 class="worldview__h">{t.title}</h3>
        <p class="worldview__body">{t.body}</p>
      </article>
    ))}
  </div>
  <p class="worldview__sub mono">
    <span aria-hidden="true">"</span>I am nothing, thus, I can do anything.<span aria-hidden="true">"</span>
  </p>
</section>

<style>
  .worldview {
    background: var(--otb-black);
    color: var(--otb-white);
  }
  .worldview__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    margin-bottom: clamp(3rem, 7vw, 5rem);
    max-width: 1100px;
    margin-inline: auto;
  }
  @media (max-width: 760px) {
    .worldview__grid {
      grid-template-columns: 1fr;
    }
  }
  .worldview__col {
    border-top: 1px solid var(--accent);
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .worldview__n {
    font-family: 'NHaas Text';
    font-size: var(--scale-mono);
    letter-spacing: var(--track-upper);
    color: var(--accent);
  }
  .worldview__h {
    font-size: clamp(1.6rem, 2.8vw, 2.4rem);
    line-height: 1.08;
    letter-spacing: var(--track-tight);
    max-width: 22ch;
  }
  .worldview__body {
    font-size: var(--scale-body);
    line-height: 1.6;
    color: var(--otb-light-gray);
    max-width: 46ch;
  }
  .worldview__sub {
    text-align: center;
    color: var(--otb-mid-gray);
    max-width: 100%;
  }
</style>
