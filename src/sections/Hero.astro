---
import LanguageToggle from '../components/LanguageToggle.astro';
import Typewriter from '../components/Typewriter.astro';
import { t } from '../i18n/t.js';

const L = Astro.currentLocale;
const isEN = !L || L === 'en';
const home = isEN ? '/' : `/${L}/`;
const link = (hash) => `${home}#${hash}`;
---
<section class="hero" id="top">
  <div class="bias-stripe" aria-hidden="true">
    <svg viewBox="0 0 100 100" preserveAspectRatio="none">
      <polygon points="100,0 100,18 18,100 0,100" fill="#E30613" />
    </svg>
  </div>

  <header class="hero__chrome">
    <span class="hero__mark-spacer" aria-hidden="true"></span>
    <nav class="hero__nav mono">
      <a href={link('manifesto')}>{t(L, 'nav.manifesto')}</a>
      <a href={link('marginalia')}>{t(L, 'nav.marginalia')}</a>
      <a href={link('worldview')}>{t(L, 'nav.worldview')}</a>
      <a href={link('arsenal')}>{t(L, 'nav.arsenal')}</a>
      <a href={link('vita')}>{t(L, 'nav.vita')}</a>
      <a href={link('obsessions')}>{t(L, 'nav.obsessions')}</a>
      <a href={link('cabinet')}>{t(L, 'nav.cabinet')}</a>
      <a href={link('write')}>{t(L, 'nav.contact')}</a>
    </nav>
  </header>

  <div class="hero__center">
    <h1 class="hero__name" translate="no">
      <span class="hero__line"><Typewriter text="JACK (B.)" /></span>
      <span class="hero__line hero__line--accent"><Typewriter text="WIESE" /></span>
    </h1>
    <p class="mono hero__est" translate="no">{t(L, 'hero.est')}</p>
    <div class="hero__motto">
      <LanguageToggle />
    </div>
    <p class="hero__tags mono" translate="no">{t(L, 'hero.tags')}</p>
    <p class="hero__sig"><em translate="no">fabulator qui coniungit</em> - {t(L, 'hero.sigSuffix')}</p>
  </div>

  <a href={link('manifesto')} class="hero__scroll mono" aria-label="Scroll to next section">
    {t(L, 'hero.scroll')} ↓
  </a>
</section>

<style>
  .hero {
    min-height: 100vh;
    background: var(--otb-black);
    color: var(--otb-white);
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: clamp(1.25rem, 3vw, 2.25rem) var(--pad-x) clamp(1.5rem, 3vw, 2.5rem);
    position: relative;
    overflow: hidden;
  }
  .hero__chrome {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    z-index: 2;
  }
  .hero__mark-spacer {
    width: 34px;
    height: 34px;
    display: inline-block;
  }
  .hero__nav {
    display: flex;
    gap: clamp(0.5rem, 2vw, 1.5rem);
    flex-wrap: wrap;
  }
  .hero__nav a {
    border: 0;
    color: var(--otb-mid-gray);
    transition: color 140ms ease;
  }
  .hero__nav a:hover {
    color: var(--accent);
  }
  @media (max-width: 700px) {
    .hero__nav a:nth-child(n+5) { display: none; }
  }
  .hero__center {
    align-self: center;
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 2.5vw, 2rem);
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    z-index: 2;
  }
  .hero__est {
    color: var(--otb-mid-gray);
    margin: 0;
  }
  .hero__name {
    font-family: 'NHaas Display';
    font-weight: 400;
    font-size: var(--scale-hero);
    line-height: 0.86;
    letter-spacing: var(--track-wordmark);
    text-transform: uppercase;
    margin: 0;
  }
  .hero__line {
    display: block;
  }
  .hero__line--accent {
    color: var(--accent);
  }
  .hero__motto {
    margin-top: 0.5rem;
  }
  .hero__tags {
    color: var(--otb-light-gray);
  }
  .hero__sig {
    font-size: var(--scale-body);
    color: var(--otb-light-gray);
    max-width: 60ch;
    margin: 0;
  }
  .hero__scroll {
    justify-self: end;
    align-self: end;
    color: var(--otb-mid-gray);
    border: 0;
    z-index: 2;
  }
  .hero__scroll:hover {
    color: var(--accent);
  }
</style>
