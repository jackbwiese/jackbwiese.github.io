---
import HoverReveal from '../components/HoverReveal.astro';

const tiles = [
  {
    n: '01',
    title: 'ONTHEBIAS',
    years: '2024 -',
    role: 'Founder + CEO',
    body: 'The AI layer between a designer\'s mind and a factory floor. Used by 5,000+ brands across 46+ countries. Products shaped for Disney, NASA, Hermès, and Nike.',
    href: 'https://onthebias.co',
    reveal: null,
    metrics: ['50M+ products shaped', '5,000+ brands', '46+ countries'],
  },
  {
    n: '02',
    title: 'RedBoxMe × Cartier',
    years: '2025 -',
    role: 'Member',
    body: 'Paris-based philanthropic + cultural initiative under the Cartier umbrella, gathering a new generation of patrons and builders.',
    href: null,
    reveal: null,
    metrics: ['Paris', 'Patronage'],
  },
  {
    n: '03',
    title: 'The Residency',
    years: '2026',
    role: 'Cohort Founder',
    body: 'Summer cohort. San Francisco. Founders building for the long horizon.',
    href: null,
    reveal: null,
    metrics: ['Summer 2026', 'San Francisco', 'Backed by Sam Altman', '~1% acceptance rate'],
  },
  {
    n: '04',
    title: 'HRMTG',
    years: '2021 - 2024',
    role: 'Founder',
    body: 'Historical Reinterpretations Made Through Garments. A streetwear label shipped to 12+ countries. Campaign partner with Free Arts NYC.',
    href: null,
    reveal: '/images/vfma-1.jpg',
    revealAlt: 'HRMTG',
    metrics: ['12+ countries', 'Free Arts NYC'],
  },
  {
    n: '05',
    title: 'Back by Popular Demand',
    years: '2017 - 2024',
    role: 'Founder, age 14',
    body: 'A vintage label run out of a bedroom from age fourteen. 10,000+ pieces moved. Paid for college zero loans.',
    href: null,
    reveal: null,
    metrics: ['10,000+ pieces', 'Zero student debt'],
  },
  {
    n: '06',
    title: 'Studio Consulting',
    years: '2024 -',
    role: 'Brand + Marketing',
    body: 'Brand identity, narrative, and growth for founders building physical-product companies worth building.',
    href: null,
    reveal: null,
    metrics: ['Brand', 'Narrative', 'Growth'],
  },
];
---
<section class="section section--invert arsenal" id="arsenal">
  <span class="eyebrow">§ V · Arsenal</span>
  <h2 class="arsenal__heading">
    Involvement.
  </h2>

  <div class="arsenal__grid">
    {tiles.map((t, i) => (
      <article class={`tile tile--${i % 3 === 1 ? 'shift' : 'flat'}`}>
        <header class="tile__head">
          <span class="tile__n mono">{t.n}</span>
          <span class="tile__years mono">{t.years}</span>
        </header>
        <h3 class="tile__title">
          {t.href ? (
            t.reveal ? (
              <HoverReveal src={t.reveal} alt={t.revealAlt}>
                <a href={t.href} rel="noopener" target="_blank">{t.title} ↗</a>
              </HoverReveal>
            ) : (
              <a href={t.href} rel="noopener" target="_blank">{t.title} ↗</a>
            )
          ) : t.reveal ? (
            <HoverReveal src={t.reveal} alt={t.revealAlt}>{t.title}</HoverReveal>
          ) : (
            t.title
          )}
        </h3>
        <p class="tile__role mono">{t.role}</p>
        <p class="tile__body">{t.body}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .arsenal {
    background: var(--otb-white);
    color: var(--otb-black);
  }
  .arsenal__heading {
    font-size: clamp(1.75rem, 4.5vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: var(--track-tight);
    margin-bottom: clamp(2.5rem, 5vw, 4.5rem);
    max-width: 22ch;
  }
  .arsenal__grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: clamp(1.5rem, 3vw, 3rem);
  }
  @media (max-width: 900px) {
    .arsenal__grid { grid-template-columns: 1fr; }
  }
  .tile {
    border-top: 1px solid var(--otb-black);
    padding: 1.25rem 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 280px;
  }
  .tile--shift { padding-top: 2.5rem; }
  @media (max-width: 900px) { .tile--shift { padding-top: 1.25rem; } }
  .tile__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    color: var(--otb-mid-gray);
  }
  .tile__n { color: var(--accent); }
  .tile__title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.02;
    letter-spacing: var(--track-tight);
    margin: 0.25rem 0 0.25rem;
  }
  .tile__title a {
    border: 0;
    background: linear-gradient(to top, var(--accent) 0%, var(--accent) 4%, transparent 4%);
    padding-bottom: 2px;
    transition: color 140ms ease;
  }
  .tile__title a:hover { color: var(--accent); }
  .tile__role {
    color: var(--otb-mid-gray);
    margin: 0;
  }
  .tile__body {
    font-size: var(--scale-body);
    line-height: 1.5;
    margin: 0;
  }
</style>
