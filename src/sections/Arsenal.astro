---
import HoverReveal from '../components/HoverReveal.astro';
import { t, tArr } from '../i18n/t.js';

const L = Astro.currentLocale;
const tiles = tArr(L, 'arsenal.tiles');

// Hrefs and reveals are NOT translated - they live alongside the locale data here.
const META = [
  { href: 'https://onthebias.co', reveal: null, revealAlt: null },
  { href: null, reveal: null, revealAlt: null },
  { href: null, reveal: null, revealAlt: null },
  { href: null, reveal: '/images/vfma-1.jpg', revealAlt: 'HRMTG' },
  { href: null, reveal: null, revealAlt: null },
  { href: null, reveal: null, revealAlt: null },
];
---
<section class="section section--invert arsenal" id="arsenal">
  <span class="eyebrow">{t(L, 'arsenal.eyebrow')}</span>
  <h2 class="arsenal__heading">
    {t(L, 'arsenal.heading')}
  </h2>

  <div class="arsenal__grid">
    {tiles.map((tile, i) => {
      const m = META[i] || {};
      const n = String(i + 1).padStart(2, '0');
      return (
        <article class={`tile tile--${i % 3 === 1 ? 'shift' : 'flat'}`}>
          <header class="tile__head">
            <span class="tile__n mono">{n}</span>
            <span class="tile__years mono">{tile.years}</span>
          </header>
          <h3 class="tile__title">
            {m.href ? (
              m.reveal ? (
                <HoverReveal src={m.reveal} alt={m.revealAlt}>
                  <a href={m.href} rel="noopener" target="_blank">{tile.title} ↗</a>
                </HoverReveal>
              ) : (
                <a href={m.href} rel="noopener" target="_blank">{tile.title} ↗</a>
              )
            ) : m.reveal ? (
              <HoverReveal src={m.reveal} alt={m.revealAlt}>{tile.title}</HoverReveal>
            ) : (
              tile.title
            )}
          </h3>
          <p class="tile__role mono">{tile.role}</p>
          <p class="tile__body">{tile.body}</p>
        </article>
      );
    })}
  </div>
</section>

<style>
  .arsenal {
    background: var(--otb-white);
    color: var(--otb-black);
  }
  .arsenal__heading {
    font-size: clamp(1.75rem, 4.5vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: var(--track-tight);
    margin-bottom: clamp(2.5rem, 5vw, 4.5rem);
    max-width: 22ch;
  }
  .arsenal__grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: clamp(1.5rem, 3vw, 3rem);
  }
  @media (max-width: 900px) {
    .arsenal__grid { grid-template-columns: 1fr; }
  }
  .tile {
    border-top: 1px solid var(--otb-black);
    padding: 1.25rem 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 280px;
  }
  .tile--shift { padding-top: 2.5rem; }
  @media (max-width: 900px) { .tile--shift { padding-top: 1.25rem; } }
  .tile__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    color: var(--otb-mid-gray);
  }
  .tile__n { color: var(--accent); }
  .tile__title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.02;
    letter-spacing: var(--track-tight);
    margin: 0.25rem 0 0.25rem;
  }
  .tile__title a {
    border: 0;
    background: linear-gradient(to top, var(--accent) 0%, var(--accent) 4%, transparent 4%);
    padding-bottom: 2px;
    transition: color 140ms ease;
  }
  .tile__title a:hover { color: var(--accent); }
  .tile__role {
    color: var(--otb-mid-gray);
    margin: 0;
  }
  .tile__body {
    font-size: var(--scale-body);
    line-height: 1.5;
    margin: 0;
  }
</style>
