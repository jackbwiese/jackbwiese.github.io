---
import { t } from '../i18n/t.js';
const L = Astro.currentLocale;
---
<section class="section section--invert manifesto" id="manifesto">
  <span class="eyebrow">{t(L, 'manifesto.eyebrow')}</span>

  <div class="manifesto__inner">
    <h2 class="manifesto__lede">
      {t(L, 'manifesto.ledePrefix')} <span class="accent" translate="no">fabulator qui coniungit</span>{t(L, 'manifesto.ledeSuffix')}
    </h2>

    <p class="manifesto__purpose">
      {t(L, 'manifesto.purposeP1')} <span class="accent">{t(L, 'manifesto.purposeAccent1')}</span> {t(L, 'manifesto.purposeP2')}
      <span class="accent">{t(L, 'manifesto.purposeAccent2')}</span>{t(L, 'manifesto.purposeP3')}
    </p>
  </div>
</section>

<style>
  .manifesto {
    background: var(--otb-white);
    color: var(--otb-black);
  }
  .manifesto__inner {
    max-width: min(72ch, 100%);
    margin: 0 auto;
    padding-block: clamp(1rem, 4vw, 3rem);
  }
  .manifesto__lede {
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 1.06;
    letter-spacing: var(--track-tight);
    margin: 0 0 clamp(2rem, 4vw, 3.5rem);
  }
  .manifesto__lede .accent { color: var(--accent); font-style: italic; }
  .manifesto__purpose {
    font-family: 'NHaas Display';
    font-weight: 300;
    font-size: clamp(1.4rem, 3vw, 2.4rem);
    line-height: 1.18;
    letter-spacing: var(--track-tight);
    margin: 0;
    color: var(--otb-black);
  }
  .manifesto__purpose .accent { color: var(--accent); }
</style>
